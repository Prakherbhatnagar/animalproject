# Copy to .env.local (not committed). Vite exposes only vars prefixed with VITE_.

# Optional in dev: leave unset to use Vite proxy to localhost:5000.
# Production: set to your API origin if different from the site (e.g. https://api.example.com).
# VITE_API_URL=https://api.example.com

VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
